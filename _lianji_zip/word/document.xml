astAsia"/></w:rPr><w:t>的装备啊</w:t></w:r></w:p><w:p w14:paraId="2A016B76" w14:textId="06C84676" w:rsidR="00307648" w:rsidRDefault="00307648"><w:r><w:rPr><w:noProof/></w:rPr><w:drawing><wp:inline distT="0" distB="0" distL="0" distR="0" wp14:anchorId="4C43CE3F" wp14:editId="0F19B892"><wp:extent cx="2993366" cy="4040647"/><wp:effectExtent l="0" t="0" r="0" b="0"/><wp:docPr id="1279532041" name="图片 1"/><wp:cNvGraphicFramePr><a:graphicFrameLocks xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" noChangeAspect="1"/></wp:cNvGraphicFramePr><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="1279532041" name=""/><pic:cNvPicPr/></pic:nvPicPr><pic:blipFill><a:blip r:embed="rId8"/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr><a:xfrm><a:off x="0" y="0"/><a:ext cx="2998007" cy="4046912"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p w14:paraId="10ACF256" w14:textId="128A7B9D" w:rsidR="00307648" w:rsidRDefault="00307648"><w:r><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr><w:t>卸下到</w:t></w:r><w:proofErr w:type="spellStart"/><w:r><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr><w:t>npc</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr><w:t>的存储空间，然后在存储空间点这个</w:t></w:r><w:r><w:rPr><w:noProof/></w:rPr><w:drawing><wp:inline distT="0" distB="0" distL="0" distR="0" wp14:anchorId="65B4ED7B" wp14:editId="69077168"><wp:extent cx="1076190" cy="685714"/><wp:effectExtent l="0" t="0" r="0" b="635"/><wp:docPr id="96149985" name="图片 1"/><wp:cNvGraphicFramePr><a:graphicFrameLocks xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" noChangeAspect="1"/></wp:cNvGraphicFramePr><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="96149985" name=""/><pic:cNvPicPr/></pic:nvPicPr><pic:blipFill><a:blip r:embed="rId9"/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr><a:xfrm><a:off x="0" y="0"/><a:ext cx="1076190" cy="685714"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r></w:p><w:p w14:paraId="588A3152" w14:textId="7A2EAFCD" w:rsidR="00307648" w:rsidRPr="00307648" w:rsidRDefault="00307648"><w:pPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr><w:r><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr><w:t>直接就到了自己的口袋里，感觉可以设计一个好感度解锁</w:t></w:r><w:proofErr w:type="spellStart"/><w:r><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr><w:t>npc</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr><w:t>背包操控的限制</w:t></w:r></w:p><w:p w14:paraId="58D084D5" w14:textId="77777777" w:rsidR="00307648" w:rsidRDefault="00307648"/><w:p w14:paraId="48974CF5" w14:textId="77777777" w:rsidR="00307648" w:rsidRDefault="00307648"/><w:p w14:paraId="574E18F4" w14:textId="6DE8D994" w:rsidR="002948AE" w:rsidRDefault="002948AE"/><w:p w14:paraId="46E8E14B" w14:textId="77777777" w:rsidR="002948AE" w:rsidRDefault="002948AE"/><w:p w14:paraId="01B43036" w14:textId="77777777" w:rsidR="002948AE" w:rsidRDefault="002948AE"/><w:p w14:paraId="32B8BB47" w14:textId="77777777" w:rsidR="002948AE" w:rsidRDefault="002948AE"/><w:p w14:paraId="27CE661D" w14:textId="77777777" w:rsidR="002948AE" w:rsidRDefault="002948AE"/><w:p w14:paraId="37D80EEE" w14:textId="77777777" w:rsidR="002948AE" w:rsidRDefault="002948AE"/><w:p w14:paraId="7BB9941C" w14:textId="77777777" w:rsidR="002948AE" w:rsidRDefault="002948AE"/><w:p w14:paraId="2932719A" w14:textId="69C5971C" w:rsidR="002948AE" w:rsidRDefault="002948AE"><w:r><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr><w:lastRenderedPageBreak/><w:t>然后变量的话好像是跟房主走的，所以配合上面的扒掉，可以每一轮正文都扒一次</w:t></w:r><w:proofErr w:type="spellStart"/><w:r><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr><w:t>npc</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr><w:t>装备，直接进货了</w:t></w:r><w:r w:rsidR="008A479D"><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr><w:t>，而且1回合的变量好像是跟着第二回合的正文发送给其他人的，</w:t></w:r></w:p><w:p w14:paraId="101213D5" w14:textId="77777777" w:rsidR="008A479D" w:rsidRDefault="008A479D"/><w:p w14:paraId="3BD2C275" w14:textId="5FC3ECBE" w:rsidR="008A479D" w:rsidRDefault="008A479D"><w:r><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr><w:t>我感觉联机能不能用这种方式，这样的话体验感会好很多，而且这样的话两边都能自己生成变量了，不然会出现房主的技能出现在另一个人的user身上</w:t></w:r><w:r><w:rPr><w:noProof/></w:rPr><w:drawing><wp:inline distT="0" distB="0" distL="0" distR="0" wp14:anchorId="7A5E27A9" wp14:editId="238E8432"><wp:extent cx="5274310" cy="4011930"/><wp:effectExtent l="0" t="0" r="2540" b="7620"/><wp:docPr id="40518284" name="图片 1"/><wp:cNvGraphicFramePr><a:graphicFrameLocks xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main" noChangeAspect="1"/></wp:cNvGraphicFramePr><a:graphic xmlns:a="http://schemas.openxmlformats.org/drawingml/2006/main"><a:graphicData uri="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:pic xmlns:pic="http://schemas.openxmlformats.org/drawingml/2006/picture"><pic:nvPicPr><pic:cNvPr id="40518284" name=""/><pic:cNvPicPr/></pic:nvPicPr><pic:blipFill><a:blip r:embed="rId10"/><a:stretch><a:fillRect/></a:stretch></pic:blipFill><pic:spPr><a:xfrm><a:off x="0" y="0"/><a:ext cx="5274310" cy="4011930"/></a:xfrm><a:prstGeom prst="rect"><a:avLst/></a:prstGeom></pic:spPr></pic:pic></a:graphicData></a:graphic></wp:inline></w:drawing></w:r><w:r><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr><w:t>：</w:t></w:r></w:p><w:p w14:paraId="14F82185" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D"/><w:p w14:paraId="5A8E4C17" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>基于“主控-分支-对齐”架构的联机 AI RP 双视角同步方案</w:t></w:r></w:p><w:p w14:paraId="2009FE27" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>一、 系统角色定义</w:t></w:r></w:p><w:p w14:paraId="3A67D1F2" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>主控 AI（Master AI）：</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t xml:space="preserve"> 使用房主（Host）的 API。拥有全知视角（掌握 A 和 B 的所有秘密、背景、当前动作和心理）。负责</w:t></w:r><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>全局大纲设计</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t>与</w:t></w:r><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>最终逻辑对齐</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t>。</w:t></w:r></w:p><w:p w14:paraId="3BEDF819" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>角色 AI-A（Agent A）：</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t xml:space="preserve"> 使用玩家 A 的 API 或本地模型。负责以 A 的视角、语气和感官来渲染正文。</w:t></w:r></w:p><w:p w14:paraId="33539FFD" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="1"/></w:numPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>角色 AI-B（Agent B）：</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t xml:space="preserve"> 使用玩家 B 的 API 或本地模型。负责以 B 的视角、语气和感官来渲染正文。</w:t></w:r></w:p><w:p w14:paraId="2A2D7CA3" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:lastRenderedPageBreak/><w:t>二、 核心工作流（四步循环法）</w:t></w:r></w:p><w:p w14:paraId="2E1336E2" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Step 1: 动作搜集与大纲生成（主控第一轮）</w:t></w:r></w:p><w:p w14:paraId="322D4263" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>输入：</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t xml:space="preserve"> 玩家 A 提交的动作 + 玩家 B 提交的动作 + 当前世界状态。</w:t></w:r></w:p><w:p w14:paraId="0D5891FB" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>主控任务：</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t xml:space="preserve"> 判定这两个动作组合后，合乎逻辑的</w:t></w:r><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>实际发生结果</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t>是什么。</w:t></w:r></w:p><w:p w14:paraId="19E4FEA3" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>输出（两条视野大纲）：</w:t></w:r></w:p><w:p w14:paraId="01096C64" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:numPr><w:ilvl w:val="1"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>大纲 A（发给 AI-A）：</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t xml:space="preserve"> 明确告知 A 这一轮你的动作产生了什么结果，你看到了什么（包含 B 的表现，但基于 A 的视角）。</w:t></w:r></w:p><w:p w14:paraId="618FDC24" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:numPr><w:ilvl w:val="1"/><w:numId w:val="2"/></w:numPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>大纲 B（发给 AI-B）：</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t xml:space="preserve"> 明确告知 B 这一轮你的动作产生了什么结果，你看到了什么（包含 A 的表现，但基于 B 的视角）。</w:t></w:r></w:p><w:p w14:paraId="66FD4A89" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Step 2: 分支视角正文渲染（各自 AI 生成）</w:t></w:r></w:p><w:p w14:paraId="1E215FEF" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="3"/></w:numPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>输入：</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t xml:space="preserve"> 各自收到主控发来的专属大纲。</w:t></w:r></w:p><w:p w14:paraId="016A1876" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="3"/></w:numPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>任务：</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t xml:space="preserve"> AI-A 和 AI-B 独立运行，根据大纲扩写成符合各自人设、文笔、感官描写（心理活动、视觉、听觉）的</w:t></w:r><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>正文初稿</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t>。</w:t></w:r></w:p><w:p w14:paraId="5E392907" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="3"/></w:numPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>输出：</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t xml:space="preserve"> 正文初稿 A、正文初稿 B。</w:t></w:r></w:p><w:p w14:paraId="51E7DA4B" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Step 3: 逻辑冲突对齐修正（主控第二轮）</w:t></w:r></w:p><w:p w14:paraId="46AE5200" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="4"/></w:numPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>输入：</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t xml:space="preserve"> 正文初稿 A + 正文初稿 B + 第一步的原始大纲。</w:t></w:r></w:p><w:p w14:paraId="288CB347" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="4"/></w:numPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>主控任务（核心控制）：</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t xml:space="preserve"> 检查两份正文是否存在</w:t></w:r><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>客观事实上的冲突</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t>。</w:t></w:r></w:p><w:p w14:paraId="38C66623" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>冲突示例：</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t xml:space="preserve"> A 的正文写到“我一拳打在 B 脸上，B 倒退三步”；而 B 的正文写到“我侧身闪过了 A 的拳头，并冷笑”。</w:t></w:r></w:p><w:p w14:paraId="2E492129" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>主控修正逻辑：</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t xml:space="preserve"> 依据第一步大纲（假设大纲定的是 A 击中），保留 B 的语气和心理描写，但将 B 的动作</w:t></w:r><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>修正</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t>为“我没能完全闪过，被拳风扫到/击中，倒退了几步，但我依然冷笑”。</w:t></w:r></w:p><w:p w14:paraId="4689F092" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="4"/></w:numPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>输出：</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t xml:space="preserve"> 修正后的最终正文 A、最终正文 B。</w:t></w:r></w:p><w:p w14:paraId="34DEE03D" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Step 4: 前端分发与展示</w:t></w:r></w:p><w:p w14:paraId="654D5DC6" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="5"/></w:numPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>结果：</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t xml:space="preserve"> 最终正文 A 发送到玩家 A 的酒馆前端；最终正文 B 发送到玩家 B 的酒馆前端。双方看到的剧情发展客观一致，但主观体验完全不同。</w:t></w:r></w:p><w:p w14:paraId="6413580F" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>三、 关键提示词（Prompt）设计方向</w:t></w:r></w:p><w:p w14:paraId="55261D33" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:r w:rsidRPr="008A479D"><w:t>为了让主控 AI 完美执行第三步的“修正”工作，主控的系统提示词（System Prompt）可以这样设计：</w:t></w:r></w:p><w:p w14:paraId="323B20FE" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:lastRenderedPageBreak/><w:t>主控 AI 修正指令：</w:t></w:r></w:p><w:p w14:paraId="216D8698" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:r w:rsidRPr="008A479D"><w:t>你现在的任务是</w:t></w:r><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>逻辑对齐审计员</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t>。你手里有原始大纲、玩家 A 的视角初稿、玩家 B 的视角初稿。</w:t></w:r></w:p><w:p w14:paraId="01D1324A" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="6"/></w:numPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>检查客观事实：</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t xml:space="preserve"> 确保两份初稿在物理世界发生的事情（谁受伤了、谁拿到了道具、谁先说话）完全一致。</w:t></w:r></w:p><w:p w14:paraId="5182F5C8" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="6"/></w:numPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>最小化修改：</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t xml:space="preserve"> </w:t></w:r><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>严禁重新生成整段文字！</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t xml:space="preserve"> 必须保留 A 和 B 原文的文笔、遣词造句和心理描写。只针对产生逻辑冲突的客观动作进行微调（增删或改动几个字词），使其顺应大纲。</w:t></w:r></w:p><w:p w14:paraId="281BDCA4" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="6"/></w:numPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>输出格式：</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t xml:space="preserve"> 严格按照 JSON 格式分别返回修改后的正文 A 和正文 B。</w:t></w:r></w:p><w:p w14:paraId="4FEC4808" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:rPr><w:b/><w:bCs/></w:rPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>四、 方案优势</w:t></w:r></w:p><w:p w14:paraId="36944D8C" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="7"/></w:numPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>真正的双视角体验：</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t xml:space="preserve"> A 能看到 B 看不到的盲区，B 也能有自己的心理活动，不再像以前</w:t></w:r><w:proofErr w:type="gramStart"/><w:r w:rsidRPr="008A479D"><w:t>联机跑团那样</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r w:rsidRPr="008A479D"><w:t>，两个人的聊天记录一模一样，失去了“各怀鬼胎”的乐趣。</w:t></w:r></w:p><w:p w14:paraId="726FCA40" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="7"/></w:numPr></w:pPr><w:proofErr w:type="gramStart"/><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>零机制</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>冲突：</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t xml:space="preserve"> 由主控 AI 判定“判定骰”或动作结果，彻底解决了“判定打架”（我说打中了，你说闪开了）的联机死结。</w:t></w:r></w:p><w:p w14:paraId="45AEE3A6" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:pPr><w:numPr><w:ilvl w:val="0"/><w:numId w:val="7"/></w:numPr></w:pPr><w:r w:rsidRPr="008A479D"><w:rPr><w:b/><w:bCs/></w:rPr><w:t>Token 友好型修正：</w:t></w:r><w:r w:rsidRPr="008A479D"><w:t xml:space="preserve"> 第三轮主控只做 Edit（修改）而不是 Generate（生成），通常可以使用速度快、上下</w:t></w:r><w:proofErr w:type="gramStart"/><w:r w:rsidRPr="008A479D"><w:t>文理解强的</w:t></w:r><w:proofErr w:type="gramEnd"/><w:r w:rsidRPr="008A479D"><w:t>轻量模型（如 Gemini 1.5 Flash 或 GPT-4o-mini）来降低成本和延迟。</w:t></w:r></w:p><w:p w14:paraId="61602E72" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:r w:rsidRPr="008A479D"><w:t>这个方案如果能通过酒馆（</w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="008A479D"><w:t>SillyTavern</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="008A479D"><w:t>）的 Extension（扩展插件）或者配合 Make/</w:t></w:r><w:proofErr w:type="spellStart"/><w:r w:rsidRPr="008A479D"><w:t>Flowise</w:t></w:r><w:proofErr w:type="spellEnd"/><w:r w:rsidRPr="008A479D"><w:t xml:space="preserve"> 等工作流工具接出来，绝对会成为联机 RP 的神器。</w:t></w:r></w:p><w:p w14:paraId="41E2AEC5" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D" w:rsidP="008A479D"><w:r w:rsidRPr="008A479D"><w:t>你目前是打算把这个构想做成自定义的脚本/工作流，还是在寻找现有的酒馆插件来实现类似的功能？</w:t></w:r></w:p><w:p w14:paraId="1459E093" w14:textId="77777777" w:rsidR="008A479D" w:rsidRPr="008A479D" w:rsidRDefault="008A479D"><w:pPr><w:rPr><w:rFonts w:hint="eastAsia"/></w:rPr></w:pPr></w:p><w:sectPr w:rsidR="008A479D" w:rsidRPr="008A479D"><w:pgSz w:w="11906" w:h="16838"/><w:pgMar w:top="1440" w:right="1800" w:bottom="1440" w:left="1800" w:header="851" w:footer="992" w:gutter="0"/><w:cols w:space="425"/><w:docGrid w:type="lines" w:linePitch="312"/></w:sectPr></w:body></w:document>