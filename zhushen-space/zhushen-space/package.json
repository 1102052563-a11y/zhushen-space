{
  "name": "zhushen-space",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/check-types.mjs && vite build",
    "typecheck": "node scripts/check-types.mjs",
    "typecheck:update": "node scripts/check-types.mjs --update",
    "test": "vitest run",
    "test:watch": "vitest",
    "preview": "vite preview",
    "build-vectors": "node tools/build-novel-vectors.mjs",
    "build-vectors-wb": "node tools/build-novel-vectors.mjs --input=../../______.json --out=public/worldbook-vectors",
    "nai": "node tools/nai-batch/nai-batch.mjs",
    "nai-ui": "node tools/nai-batch/server.mjs",
    "upload-r2": "node tools/upload-r2/upload-r2.mjs"
  },
  "dependencies": {
    "@dicebear/collection": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@types/howler": "^2.2.13",
    "howler": "^2.2.4",
    "lz-string": "^1.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sql.js": "^1.14.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1069.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.7",
    "typescript": "^5.5.4",
    "vite": "^5.3.5",
    "vitest": "^3.2.6"
  }
}
