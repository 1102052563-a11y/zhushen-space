93\u5c55\u73fe\u51fa\u4e0d\u540c\u9762\u8c8c\u3002\n|-\n||<center>\u4ea4\u6613\u7cfb\u7d71<ref>{{Cite web |url=http://x6.changyou.com/x6/news/20130711/60911.shtml |title=\u667a\u9b25\u5978\u5546NPC \u300a\u8ed2\u8f45\u528d6\u300b\u4ea4\u6613\u7384\u6a5f\u6436\u5148\u770b  |access-date=2013-07-11 |archive-url=https://web.archive.org/web/20150121073446/http://x6.changyou.com/x6/news/20130711/60911.shtml |archive-date=2015-01-21 |dead-url=yes }}</ref></center>|| \u63d0\u4f9b\u4ee5\u7269\u6613\u7269\u53caVIP\u7b49\u4ea4\u6613\u529f\u80fd\u3002\n|-\n||<center>\u5343\u5175\u7cfb\u7d71<ref>{{Cite web |url=http://x6.changyou.com/x6/news/20131030/63880.shtml |title=\u6d4a\u5c71\u94f8\u5f52\u6765\uff01\u300a\u8f69\u8f95\u5251\u9646\u300bDLC\u53ef\u63a7\u89d2\u8272\u66dd\u5149  |access-date=2013-11-20 |archive-url=https://web.archive.org/web/20131204082011/http://x6.changyou.com/x6/news/20131030/63880.shtml |archive-date=2013-12-04 |dead-url=yes }}</ref></center>|| \u4e8e\u300a\u5929\u5916\u4e4b\u7ae0DLC\uff1a\u6fc1\u5c71\u9444\u7bc7\u300b\u4e2d\u51fa\u73fe\uff0c\u9ed1\u706b\u9580\u7368\u6709\uff0c\u53ef\u6539\u8b8a\u672c\u8eab\u9ad4\u8cea\u4e26\u589e\u5f37\u6230\u7532\u5e2b\u5404\u7a2e\u80fd\u529b\u3002\n|-\n||<center>\u5929\u66f8\u7cfb\u7d71</center>|| \u4e8e\u300a\u5929\u5916\u4e4b\u7ae0DLC\uff1a\u6fc1\u5c71\u9444\u7bc7\u300b\u4e2d\u51fa\u73fe\uff0c\u5305\u542b\u672c\u50b3\u58fa\u4e2d\u4e16\u754c\u7cfb\u7d71\u4e2d\u9664\u9b3c\u795e\u4e4b\u5854\u53ca\u958b\u555f\u96b1\u85cf\u652f\u7dda\u3001\u96b1\u85cf\u8ff7\u5bae\u9019\u5e7e\u9805\u529f\u80fd\u5916\u7684\u5176\u4ed6\u5168\u90e8\u529f\u80fd\u3002\n|}\n\n==\u904a\u6232\u4e3b\u984c\u6b4c\u66f2==\n'''\u7247\u982d\u66f2\u300c\u9cf3\u51cc\u9577\u7a7a\u300d'''\n:\u4f5c\u8a5e\uff1a\u65b9\u5b81 / \u4f5c\u66f2\uff1a\u5434\u6b23-{\u53e1}- / \u7f16\u66f2\uff1a\u9648\u98de\u5348 / \u6b4c\u66f2\u88fd\u4f5c\uff1a[[\u9773\u9435\u7ae0]] / \u6b4c\uff1a[[\u66fe\u5a01\u8c6a]]\n'''\u7247\u5c3e\u66f2\u300c\u5343\u5e74\u9189\u300d'''\n:\u4f5c\u8a5e\uff1a\u5c0f\u671b / \u4f5c\u66f2\uff1a\u66fe\u5fd7\u8c6a / \u7f16\u66f2\uff1a\u9648\u98de\u5348 / \u6b4c\u66f2\u88fd\u4f5c\uff1a[[\u9773\u9435\u7ae0]] / \u6b4c\uff1a\u5ed6\u7fbd\n\n==\u9500\u552e==\n*2013\u5e746\u670824\u65e5\uff0c\u53f0\u7063\u8207\u4e2d\u570b\u5927\u9678\u540c\u6b65\u9810\u8cfc\uff0c\u53f0\u7063\u70ba\u5e73\u88dd\u8207\u7cbe\u88dd\u5169\u7248<ref>{{Cite web |url=http://km.softstar.com.tw/topic.aspx?tid=526 |title=\u300a\u8ed2\u8f45\u528d\u9678\u300b6/24\u9810\u8cfc\u958b\u8dd1\uff01\u7cbe\u88ddQ\u7248\u4e3b\u89d2\u516c\u4ed4\u4eae\u773c\u5438\u775b\uff01 |access-date=2013-06-20 |archive-date=2020-06-28 |archive-url=https://web.archive.org/web/20200628143809/http://km.softstar.com.tw/topic.aspx?tid=526 |dead-url=no }}</ref>\uff0c\u4e2d\u570b\u5927\u9678\u9664\u6a19\u6e96\u7248\u548c\u8c6a\u83ef\u7248\u5916\uff0c\u9084\u540c\u6b65\u63a8\u51fa\u6578\u4f4d\u7248\u3002<ref>{{Cite web |url=http://x6.changyou.com/x6/news/20130620/60497.shtml |title=\u6a19\u6e96\u7248\u552e79\u5143\u300a\u8f69\u8f95\u52516\u300b6\u670824\u65e5\u5f00\u542f\u9884\u552e |access-date=2013-06-20 |archive-url=https://web.archive.org/web/20130623020026/http://x6.changyou.com/x6/news/20130620/60497.shtml |archive-date=2013-06-23 |dead-url=yes }}</ref>\n*2013\u5e748\u67089\u65e5\u7e41\u9ad4\u7248\u3001\u7c21\u9ad4\u7248\u540c\u6b65\u767c\u552e\u3002\n*\u4e0a\u5e02\u7b2c\u4e00\u5468\u4e2d\u570b\u5927\u9678\u7248\u92b7\u552e\u91cf\uff0c\u7a81\u7834\u6b77\u4ee3\u6700\u9ad830\u842c\u5957(\u4e0d\u5305\u542b\u53f0\u7248)\u3002<ref>{{Cite web |url=http://x6.changyou.com/x6/news/20130819/61907.shtml |title=\u9500\u91cf\u7a81\u783430\u842c DLC\u706b\u70ed\u5236\u4f5c\u4e2d |access-date=2013-08-19 |archive-url=https://web.archive.org/web/20130823170503/http://x6.changyou.com/x6/news/20130819/61907.shtml |archive-date=2013-08-23 |dead-url=yes }}</ref>\n*2017\u5e749\u670811\u65e5\uff0c\u66a2\u904a\u767c\u4f48\u516c\u544a\u7a31\uff0c\u56e0\u4ee3\u7406\u5408\u7d04\u5230\u671f\uff0c\u7531\u66a2\u904a\u4ee3\u7406\u767c\u552e\u7684\u7c21\u9ad4\u7248\u300a\u8ed2\u8f45\u528d\u9678\u300b\u5c07\u65bc9\u670830\u65e5\u4e2d\u534812\u6642\u8d77\u505c\u6b62\u71df\u904b\u3002\u5c46\u6642\u5df2\u555f\u52d5\u7684\u904a\u6232\u4e0d\u53d7\u5f71\u97ff\uff0c\u4f46\u672a\u555f\u52d5\u7684\u904a\u6232\u5c07\u4e0d\u80fd\u518d\u555f\u52d5\u30029\u670829\u65e5\uff0c\u5b98\u65b9\u5ba3\u4f48\uff0c\u7c21\u9ad4\u7248\u300a\u8ed2\u8f45\u528d\u9678\u300b\u6fc0\u6d3b\u670d\u52d9\u5c07\u7531\u5927\u5b87\u8cc7\u8a0a\u627f\u63a5\uff0c\u4e26\u91dd\u5c0d\u7c21\u9ad4\u7248\u88fd\u4f5c\u4e86\u7248\u672c\u865f\u70ba2.02\u7684\u904a\u6232\u66f4\u65b0\u3002\u66f4\u65b0\u7248\u672c\u5f8c\uff0c\u539f\u66a2\u904a\u7248\u555f\u52d5\u78bc\u4ecd\u53ef\u6b63\u5e38\u4f7f\u7528\u3002\n\n==\u53c3\u8003\u8cc7\u6599==\n{{reflist|3}}\n\n{{\u8ed2\u8f45\u528d}}\n\n[[Category:\u96fb\u5b50\u89d2\u8272\u626e\u6f14\u904a\u6232]]\n[[Category:Windows\u904a\u6232]]\n[[Category:\u8ed2\u8f45\u528d\u7cfb\u5217\u96fb\u5b50\u904a\u6232|6]]\n[[Category:2013\u5e74\u96fb\u5b50\u904a\u6232]]\n[[Category:\u5546\u671d\u80cc\u666f\u96fb\u5b50\u904a\u6232]]\n[[Category:\u5355\u4eba\u7535\u5b50\u6e38\u620f|Xuan10]]\n[[Category:\u897f\u5468\u80cc\u666f\u4f5c\u54c1]]"}}}