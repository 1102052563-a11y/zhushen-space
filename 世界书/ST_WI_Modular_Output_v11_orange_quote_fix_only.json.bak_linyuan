\n\u003e 条件：[action_conditions]\n\u003e 命中：🎲[hit_dice] +[hit_mod] -[eva_mod] +[hit_env_mod] =[hit_final] vs DC[hit_dc] → [hit_result]\n\u003e 暴击：率[crit_rate]｜骰[crit_roll]｜倍[crit_mul]\n\u003e 衍生属性：[PATK] / [PDEF]/ [MATK]/ [MDEF]\n\u003e 配合影响：[teamplay_effect_note]\n\u003e 结算：[final_value]\n\u003e **HP(敌)：**[enemy_hp_old]/[enemy_hp_max] -\u003e [enemy_hp_new]/[enemy_hp_max]\n\u003e 状态：[status_name]｜[status_effect_value]｜[status_duration]｜[status_stacks]层\n\u003e 消耗：MP [mp_old]/[pc_mp_max] -\u003e [mp_new]/[pc_mp_max]；\n\u003e\n\u003e **[克制窗口｜每回合战斗至少一次]**\n\u003e 窗口：[counter_window]｜工具：[counter_tools]｜不用原因：[counter_not_used_reason]\n\u003e\n\u003e **[击杀处理｜战斗内不展开结算]**\n\u003e 战斗中击杀敌人时，只在叙事里描写其死亡（点到名字/数量即可）；**【击杀结算】一律不在战斗块内逐次输出**，统一汇总到正文**最末尾**的【回合末·击杀结算】块一次性合并输出。","constant":false,"vectorized":false,"selective":true,"selectiveLogic":0,"addMemo":true,"order":70,"position":1,"disable":false,"ignoreBudget":false,"excludeRecursion":true,"preventRecursion":false,"matchPersonaDescription":false,"matchCharacterDescription":false,"matchCharacterPersonality":false,"matchCharacterDepthPrompt":false,"matchScenario":false,"matchCreatorNotes":false,"delayUntilRecursion":false,"probability":100,"useProbability":true,"depth":4,"group":"","groupOverride":false,"groupWeight":100,"scanDepth":0,"caseSensitive":false,"matchWholeWords":false,"useGroupScoring":null,"automationId":"","role":null,"sticky":0,"cooldown":0,"delay":0,"triggers":[],"displayIndex":9,"outletName":"","characterFilter":{"isExclude":false,"names":[],"tags":[]}},"10":{"uid":10,"key":["/⟦TRIG:QUEST_ADV⟧/","⟦TRIG:QUEST_ADV⟧"],"keysecondary":[],"comment":"[mvu_plot]模块-任务推进","content":"\u003e **【📜 任务 · [quest_name]（[quest_type_advanced]）｜任务出现/推进时插入】**\n\u003e ◈ 任务目标：[quest_goal_new]\n\u003e ◈ 任务简介：[quest_intro]\n\u003e ◈ 任务区域：[quest_area]\n\u003e 🎁 奖励：[quest_reward]\n\u003e 🌍 世界之源（完成必得·独立于上方🎁奖励的“四选三”之外）：完成本环/本任务 +{按任务类型取：主线强制环+10%~18%、贪婪环+15%~25%、支线+3%~7%、隐藏任务+8%~15%，依“00-铁律”第15条}（玩家可见的明细；计入全文末尾隐藏 \u003c世界之源\u003e 块的累计）\n\u003e ⚠ 惩罚：[quest_penalty]\n\u003e 💡 提示：[quest_hint_new]\n","constant":false,"vectorized":false,"selective":true,"selectiveLogic":0,"addMemo":true,"order":80,"position":1,"disable":false,"ignoreBudget":false,"excludeRecursion":true,"preventRecursion":false,"matchPersonaDescription":false,"matchCharacterDescription":false,"matchCharacterPersonality":false,"matchCharacterDepthPrompt":false,"matchScenario":false,"matchCreatorNotes":false,"delayUntilRecursion":false,"probability":100,"useProbability":true,"depth":4,"group":"","groupOverride":false,"groupWeight":100,"scanDepth":0,"caseSensitive":false,"matchWholeWords":false,"useGroupScoring":null,"automationId":"","role":null,"sticky":0,"cooldown":0,"delay":0,"triggers":[],"displayIndex":10,"outletName":"","characterFilter":{"isExclude":false,"names":[],"tags":[]}},"11":{"uid":11,"key":[],"keysecondary":[],"comment":"[mvu_plot]模块-世界之源结算(隐藏)","content":"【系统·世界之源结算（隐藏数据通道｜玩家不可见，专供世界之源结算读取）】每回合正文**最末尾**（全文最后、所有可见模块之后）必须追加下面这一隐藏块，**整回合一次、即使本回合 +0% 也要输出**；它给系统读、玩家看不到，所以**绝不要写成「\u003e」可见模块、不要加标题/表情**，照下面格式原样输出标签即可：\n\u003c世界之源\u003e本回合获得：{逐项列来源×数=小计，如 主线环完成=+15%、击杀精英×1=+2%、击杀杂兵×3=+0.9%；本回合无来源则写 +0%}｜当前世界之源：{累计总量}%（= 上回合累计 + 本回合获得，按「00-铁律」第15条口径）\u003c/世界之源\u003e","constant":true,"vectorized":false,"selective":true,"selectiveLogic":0,"addMemo":true,"order":90,"position":1,"disable":false,"ignoreBudget":true,"excludeRecursion":true,"preventRecursion":false,"matchPersonaDescription":false,"matchCharacterDescription":false,"matchCharacterPersonality":false,"matchCharacterDepthPrompt":false,"matchScenario":false,"matchCreatorNotes":false,"delayUntilRecursion":false,"probability":100,"useProbability":true,"depth":4,"group":"","groupOverride":false,"groupWeight":100,"scanDepth":0,"caseSensitive":false,"matchWholeWords":false,"useGroupScoring":null,"automationId":"","role":null,"sticky":0,"cooldown":0,"delay":0,"triggers":[],"displayIndex":11,"outletName":"","characterFilter":{"isExclude":false,"names":[],"tags":[]}}}}